{
  "name": "chennai-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "chennai-monorepo",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@appthreat/chennai": {
      "resolved": "packages/chennai",
      "link": true
    },
    "packages/chennai": {
      "name": "@appthreat/chennai",
      "version": "3.0.0",
      "license": "MIT",
      "bin": {
        "chennai": "index.js"
      },
      "engines": {
        "node": ">=18"
      },
      "optionalDependencies": {
        "@appthreat/chennai-darwin-arm64": "3.0.0",
        "@appthreat/chennai-jar": "3.0.0",
        "@appthreat/chennai-linux-amd64": "3.0.0",
        "@appthreat/chennai-linux-amd64-musl": "3.0.0",
        "@appthreat/chennai-linux-arm64": "3.0.0",
        "@appthreat/chennai-windows-amd64": "3.0.0"
      }
    }
  }
}
